MQTT_URL=mqtt://192.168.1.10:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=devices/heartbeat
MQTT_MESSAGE=heartbeat
HEARTBEAT_INTERVAL_MINUTES=5

# Optional
MQTT_QOS=1
MQTT_RETAIN=false
HEARTBEAT_PUBLISH_IMMEDIATELY=true
MQTT_KEEPALIVE_SECONDS=30
MQTT_CONNECT_TIMEOUT_SECONDS=30
MQTT_PUBLISH_TIMEOUT_SECONDS=10
MQTT_RETRY_SECONDS=10
